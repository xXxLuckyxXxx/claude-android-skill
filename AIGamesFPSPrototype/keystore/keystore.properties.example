# =============================================================================
#  Android signing configuration (EXAMPLE)
# =============================================================================
#  scripts/generate-keystore.sh creates the REAL keystore.properties next to
#  this file. The real file is git-ignored on purpose — it contains secrets.
#
#  The build pipeline (Assets/Editor/AIGamesBuild/BuildScript.cs) reads these
#  values, OR the equivalent environment variables (which take precedence):
#
#     AIGAMES_KEYSTORE_PATH      -> storeFile
#     AIGAMES_KEYSTORE_PASSWORD  -> storePassword
#     AIGAMES_KEY_ALIAS          -> keyAlias
#     AIGAMES_KEY_PASSWORD       -> keyPassword
# =============================================================================

# Path to the keystore, relative to the Unity project root (or absolute).
storeFile=keystore/aigames-release.keystore

# Store + key passwords. NEVER commit the real values.
storePassword=CHANGE_ME
keyAlias=aigames
keyPassword=CHANGE_ME
